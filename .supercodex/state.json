          "content": "import {\n  AlarmClock,\n  ArrowUp,\n  Bot,\n  BriefcaseBusiness,\n  Check,\n  ChevronDown,\n  CircleDot,\n  FileText,\n  Folder,\n  Globe2,\n  Grid3X3,\n  KeyRound,\n  Mail,\n  MessageCircle,\n  Mic,\n  PanelLeft,\n  Paperclip,\n  PenLine,\n  Plus,\n  Search,\n  Send,\n  Settings2,\n  ShieldCheck,\n  Slack,\n  Sparkles,\n  UserRound,\n  Wrench,\n  Workflow\n} from \"lucide-react\";\nimport { FormEvent, useEffect, useMemo, useState } from \"react\";\n\ntype Role = \"system\" | \"user\" | \"assistant\" | \"tool\";\n\ntype ToolCall = {\n  id: string;\n  type: \"function\";\n  function: { name: string; arguments: string };\n};\n\ntype Message = {\n  id: string;\n  role: Exclude<Role, \"system\" | \"tool\">;\n  content: string;\n  tool_calls?: ToolCall[];\n  createdAt?: string;\n  status?: \"thinking\" | \"done\" | \"error\";\n};\n\ntype ToolMessage = {\n  id: string;\n  role: \"tool\";\n  content: string;\n  tool_call_id: string;\n  createdAt?: string;\n};\n\ntype StoredMessage = Message | ToolMessage;\n\ntype ApiSettings = {\n  baseUrl: string;\n  apiKey: string;\n  model: string;\n};\n\ntype Project = {\n  id: string;\n  name: string;\n  conversations: ConversationSummary[];\n};\n\ntype ConversationSummary = {\n  id: string;\n  title: string;\n  shortcut?: string;\n  updatedAt?: string;\n  messageCount?: number;\n};\n\ntype Skill = {\n  id: \"messages\" | \"email\" | \"files\";\n  title: string;\n  description: string;\n  accent: \"slack\" | \"mail\" | \"drive\";\n  connected: boolean;\n};\n\ntype AppState = {\n  settings: ApiSettings & { configured?: boolean };\n  projects: Project[];\n  skills: Skill[];\n  automations: Array<{\n    id: string;\n    title: string;\n    schedule: string;\n    enabled: boolean;\n  }>;\n};\n\nconst defaultSettings: ApiSettings = {\n  baseUrl: \"https://api.openai.com/v1\",\n  apiKey: \"\",\n  model: \"gpt-4.1\"\n};\n\nconst skillIcons = {\n  messages: Slack,\n  email: Mail,\n  files: FileText\n};\n\nfunction App() {\n  const [messages, setMessages] = useState<StoredMessage[]>([]);\n  const [input, setInput] = useState(\"\");\n  const [projects, setProjects] = useState<Project[]>([]);\n  const [skills, setSkills] = useState<Skill[]>([]);\n  const [activeConversationId, setActiveConversationId] = useState(\"\");\n  const [settings, setSettings] = useState<ApiSettings>(defaultSettings);\n  const [isWorking, setIsWorking] = useState(false);\n  const [isBooting, setIsBooting] = useState(true);\n  const [showSettings, setShowSettings] = useState(false);\n  const [permission, setPermission] = useState(\"全部允许\");\n  const [mode, setMode] = useState<\"agent\" | \"team\">(\"agent\");\n\n  const hasConversation = messages.length > 0;\n  const activeProject = projects[0];\n  const promptTitle = useMemo(\n    () => (hasConversation ? \"SuperCodex\" : \"让 SuperCodex 帮你完成任务\"),\n    [hasConversation]\n  );\n\n  useEffect(() => {\n    loadAppState();\n  }, []);\n\n  async function loadAppState() {\n    setIsBooting(true);\n    const payload = await syncAppState();\n    const firstConversation = payload.projects[0]?.conversations[0];\n    if (firstConversation) {\n      setActiveConversationId(firstConversation.id);\n      await loadMessages(firstConversation.id);\n    }\n    setIsBooting(false);\n  }\n\n  async function syncAppState() {\n    const response = await fetch(\"/api/app\");\n    const payload = (await response.json()) as AppState;\n    setProjects(payload.projects);\n    setSkills(payload.skills);\n    setSettings({\n      baseUrl: payload.settings.baseUrl || defaultSettings.baseUrl,\n      apiKey: payload.settings.apiKey === \"********\" ? \"\" : payload.settings.apiKey,\n      model: payload.settings.model || defaultSettings.model\n    });\n    return payload;\n  }\n\n  async function loadMessages(conversationId: string) {\n    setActiveConversationId(conversationId);\n    const response = await fetch(`/api/conversations/${conversationId}/messages`);\n    const payload = (await response.json()) as { messages: Message[] };\n    setMessages(payload.messages);\n  }\n\n  async function createTask() {\n    const response = await fetch(\"/api/conversations\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({\n        projectId: activeProject?.id,\n        title: \"新任务\"\n      })\n    });\n    const conversation = (await response.json()) as ConversationSummary;\n    await syncAppState();\n    await loadMessages(conversation.id);\n  }\n\n  async function saveSettings(nextSettings = settings) {\n    const body: ApiSettings | Omit<ApiSettings, \"apiKey\"> = nextSettings.apiKey\n      ? nextSettings\n      : {\n          baseUrl: nextSettings.baseUrl,\n          model: nextSettings.model\n        };\n    const response = await fetch(\"/api/settings\", {\n      method: \"PUT\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify(body)\n    });\n    const payload = (await response.json()) as ApiSettings;\n    setSettings({\n      baseUrl: payload.baseUrl || nextSettings.baseUrl,\n      apiKey: nextSettings.apiKey,\n      model: payload.model || nextSettings.model\n    });\n  }\n\n\n... (truncated, 406 more lines)",
