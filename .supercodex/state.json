          "id": "message_ca3fa838-5927-4a3c-9520-05e9255ab72e",
          "role": "tool",
          "content": "import cors from \"cors\";\nimport \"dotenv/config\";\nimport express from \"express\";\nimport { exec } from \"node:child_process\";\nimport { promises as fs } from \"node:fs\";\nimport path from \"node:path\";\nimport { promisify } from \"node:util\";\n\nconst execAsync = promisify(exec);\nconst app = express();\nconst port = Number(process.env.PORT ?? 8787);\n\n// ─── Types ───────────────────────────────────────────────────────────────────\n\ntype Role = \"system\" | \"user\" | \"assistant\" | \"tool\";\n\ntype ToolCall = {\n  id: string;\n  type: \"function\";\n  function: { name: string; arguments: string };\n};\n\ntype ChatMessage = {\n  role: Role;\n  content: string | null;\n  tool_calls?: ToolCall[];\n  tool_call_id?: string;\n  name?: string;\n};\n\ntype ToolDefinition = {\n  type: \"function\";\n  function: {\n    name: string;\n    description: string;\n    parameters: Record<string, unknown>;\n  };\n};\n\ntype ToolResult = {\n  tool_call_id: string;\n  content: string;\n  isError?: boolean;\n};\n\ntype ApiConfig = {\n  baseUrl?: string;\n  apiKey?: string;\n  model?: string;\n};\n\ntype Message = {\n  id: string;\n  role: Exclude<Role, \"system\" | \"tool\">;\n  content: string;\n  tool_calls?: ToolCall[];\n  createdAt: string;\n};\n\ntype ToolMessage = {\n  id: string;\n  role: \"tool\";\n  content: string;\n  tool_call_id: string;\n  toolName: string;\n  createdAt: string;\n};\n\ntype StoredMessage = Message | ToolMessage;\n\ntype Conversation = {\n  id: string;\n  projectId: string;\n  title: string;\n  shortcut?: string;\n  updatedAt: string;\n  messages: StoredMessage[];\n};\n\ntype Project = {\n  id: string;\n  name: string;\n  conversations: string[];\n};\n\ntype Skill = {\n  id: string;\n  title: string;\n  description: string;\n  accent: string;\n  connected: boolean;\n  installed: boolean;\n  npmPackage?: string;\n};\n\ntype Automation = {\n  id: string;\n  title: string;\n  schedule: string;\n  enabled: boolean;\n  createdAt: string;\n};\n\ntype ChatCompletionResponse = {\n  id?: string;\n  model?: string;\n  choices?: Array<{\n    message?: {\n      content?: string;\n      tool_calls?: ToolCall[];\n    };\n  }>;\n  usage?: unknown;\n  error?: { message?: string };\n};\n\ntype PersistedStore = {\n  projects: Project[];\n  conversations: Conversation[];\n  skills: Skill[];\n  automations: Automation[];\n};\n\n// ─── Constants ───────────────────────────────────────────────────────────────\n\nconst MAX_AGENT_TURNS = 10;\nconst WORKSPACE_ROOT = process.cwd();\nconst DATA_DIR = path.join(WORKSPACE_ROOT, \".supercodex\");\nconst DATA_FILE = path.join(DATA_DIR, \"state.json\");\nconst DENIED_COMMAND_PATTERNS = [\n  /\\brm\\s+-rf\\b/,\n  /\\bgit\\s+reset\\s+--hard\\b/,\n  /\\bgit\\s+clean\\s+-fd\\b/,\n  /\\bsudo\\b/,\n  />\\s*\\/dev\\/(disk|rdisk)/,\n  /\\bmkfs\\b/,\n  /\\bdd\\s+if=/\n];\n\nconst systemPrompt =\n  \"You are SuperCodex, a general office agent. Help with workplace tasks such as email, documents, research, planning, automation, meetings, operations, and cross-app workflows. \" +\n  \"Be practical, concise, and action-oriented. \" +\n  \"You have access to tools. Use them when they can help complete the task. \" +\n  \"When a tool call is needed, respond with tool_calls. When you have the final answer, respond with plain text content.\";\n\n// ─── Settings ────────────────────────────────────────────────────────────────\n\nconst settings: Required<ApiConfig> = {\n  baseUrl: process.env.API_BASE_URL ?? \"https://api.openai.com/v1\",\n  apiKey: process.env.API_KEY ?? \"\",\n  model: process.env.API_MODEL ?? \"gpt-4.1\"\n};\n\n// ─── Tool Registry ───────────────────────────────────────────────────────────\n\nconst tools = new Map<string, ToolDefinition>();\nconst toolHandlers = new Map<string, (args: Record<string, unknown>) => Promise<string>>();\n\nfunction registerTool(definition: ToolDefinition, handler: (args: Record<string, unknown>) => Promise<string>) {\n  tools.set(definition.function.name, definition);\n  toolHandlers.set(definition.function.name, handler);\n}\n\nregisterTool(\n  {\n    type: \"function\",\n    function: {\n      name: \"search_web\",\n      description: \"Search the web for information. Returns top results.\",\n      parameters: {\n        type: \"object\",\n        properties: {\n          query: { type: \"string\", description: \"Search query\" },\n          num: { type: \"number\", description: \"Number of results (default 5)\" }\n        },\n        required: [\"query\"]\n      }\n    }\n  },\n  async (args) => {\n    const query = String(args.query || \"\");\n    const num = Number(args.num) || 5;\n    try {\n      const url = `https://html.duckduckgo.com/html/?q=${encodeURIComponent(query)}`;\n      const response = await fetch(url, {\n        headers: { \"User-Agent\": \"Mozilla/5.0\" }\n      });\n      const html = await response.text();\n      const results: string[] = [];\n      const regex = /class=\"result__a\"[^>]*href=\"([^\"]*)\"[^>]*>(.*?)<\\/a>/g;\n      let match;\n      while ((match = regex.exec(html)) !== null && results.length < num) {\n        results.push(`[${match[2]}](${match[1]})`);\n      }\n      return results.length > 0\n        ? results.map((r, i) => `${i + 1}. ${r}`).join(\"\\n\")\n        : \"No results found.\";\n    } catch (error) {\n      return `Search failed: ${error instanceof Error ? error.message : \"Unknown error\"}`;\n    }\n  }\n);\n\nregisterTool(\n  {\n    type: \"function\",\n    function: {\n      name: \"run_command\",\n      description: \"Execute a shell command and return stdout/stderr.\",\n      parameters: {\n        type: \"object\",\n        properties: {\n          command: { type: \"string\", description: \"Shell command to execute\" },\n          cwd: { type: \"string\", description: \"Working directory (optional)\" }\n        },\n        required: [\"command\"]\n      }\n    }\n  },\n  async (args) => {\n    const command = String(args.command || \"\");\n    const cwd = safeResolvePath(String(args.cwd || WORKSPACE_ROOT));\n    const denied = DENIED_COMMAND_PATTERNS.find((pattern) => pattern.test(command));\n    if (denied) {\n      return `Command blocked by SuperCodex safety policy: ${command}`;\n    }\n    try {\n      const result = await execAsync(command, {\n        cwd,\n        timeout: 30_000,\n        maxBuffer: 1024 * 1024 * 5\n      });\n      const output = [result.stdout, result.stderr].filter(Boolean).join(\"\\n\");\n      return output || \"(Command executed successfully, no output)\";\n    } catch (error) {\n      const err = error as Error & { stdout?: string; stderr?: string };\n      return `Error: ${err.stderr || err.message}`;\n    }\n  }\n);\n\nregisterTool(\n  {\n    type: \"function\",\n    function: {\n      name: \"read_file\",\n      description: \"Read the contents of a file.\",\n      parameters: {\n        type: \"object\",\n        properties: {\n          path: { type: \"string\", description: \"File path (absolute or relative)\" },\n          limit: { type: \"number\", description: \"Max lines to read (default 200)\" }\n        },\n        required: [\"path\"]\n      }\n    }\n  },\n  async (args) => {\n    const filePath = safeResolvePath(String(args.path || \"\"));\n    const limit = Number(args.limit) || 200;\n    try {\n      const content = await fs.readFile(filePath, \"utf-8\");\n      const lines = content.split(\"\\n\");\n      const truncated = lines.slice(0, limit).join(\"\\n\");\n      return lines.length > limit\n        ? `${truncated}\\n\\n... (truncated, ${lines.length - limit} more lines)`\n        : truncated;\n    } catch (error) {\n      return `Failed to read file: ${error instanceof Error ? error.message : \"Unknown error\"}`;\n    }\n  }\n);\n\nregisterTool(\n  {\n    type: \"function\",\n    function: {\n      name: \"write_file\",\n      description: \"Write content to a file.\",\n      parameters: {\n        type: \"object\",\n        properties: {\n          path: { type: \"string\", description: \"File path\" },\n          content: { type: \"string\", description: \"File content\" }\n        },\n        required: [\"path\", \"content\"]\n      }\n    }\n  },\n  async (args) => {\n    const filePath = safeResolvePath(String(args.path || \"\"));\n    const content = String(args.content || \"\");\n    try {\n      await fs.mkdir(path.dirname(filePath), { recursive: true });\n      await fs.writeFile(filePath, content, \"utf-8\");\n      return `File written successfully: ${filePath}`;\n    } catch (error) {\n      return `Failed to write file: ${error instanceof Error ? error.message : \"Unknown error\"}`;\n    }\n  }\n);\n\nregisterTool(\n  {\n    type: \"function\",\n    function: {\n      name: \"list_directory\",\n      description: \"List files and directories in a given path.\",\n      parameters: {\n        type: \"object\",\n        properties: {\n          path: { type: \"string\", description: \"Directory path (default: current working directory)\" }\n        }\n      }\n    }\n  },\n  async (args) => {\n    const dirPath = safeResolvePath(String(args.path || WORKSPACE_ROOT));\n    try {\n      const entries = await fs.readdir(dirPath, { withFileTypes: true });\n      return entries\n        .map((e) => (e.isDirectory() ? `[dir] ${e.name}` : `[file] ${e.name}`))\n        .join(\"\\n\") || \"(Empty directory)\";\n    } catch (error) {\n      return `Failed to list directory: ${error instanceof Error ? error.message : \"Unknown error\"}`;\n    }\n  }\n);\n\nregisterTool(\n  {\n    type: \"function\",\n    function: {\n      name: \"install_skill\",\n      description: \"Install a skill/package via npm. Use this to extend capabilities.\",\n      parameters: {\n        type: \"object\",\n        properties: {\n          package: { type: \"string\", description: \"npm package name to install\" },\n          save: { type: \"boolean\", description: \"Save to package.json (default true)\" }\n        },\n        required: [\"package\"]\n      }\n    }\n  },\n  async (args) => {\n    const pkg = String(args.package || \"\");\n    const save = args.save !== false;\n    const flag = save ? \"--save\" : \"\";\n    try {\n      const result = await execAsync(`npm install ${pkg} ${flag}`, {\n        cwd: process.cwd(),\n        timeout: 120_000,\n        maxBuffer: 1024 * 1024 * 10\n      });\n      skills.forEach((skill) => {\n        if (skill.npmPackage === pkg) {\n          skill.installed = true;\n        }\n      });\n      return `Package installed: ${pkg}\\n${result.stdout}`;\n    } catch (error) {\n      const err = error as Error & { stderr?: string };\n      return `Failed to install ${pkg}: ${err.stderr || err.message}`;\n    }\n  }\n);\n\nregisterTool(\n  {\n    type: \"function\",\n    function: {\n      name: \"fetch_url\",\n      description: \"Fetch the content of a URL and return as text/markdown.\",\n      parameters: {\n        type: \"object\",\n        properties: {\n          url: { type: \"string\", description: \"URL to fetch\" }\n        },\n        required: [\"url\"]\n      }\n    }\n  },\n  async (args) => {\n    const url = String(args.url || \"\");\n    try {\n      const response = await fetch(url);\n      const text = await response.text();\n      const truncated = text.slice(0, 8000);\n      return truncated.length >= 8000\n        ? `${truncated}\\n\\n... (content truncated)`\n        : truncated;\n    } catch (error) {\n      return `Failed to fetch URL: ${error instanceof Error ? error.message : \"Unknown error\"}`;\n    }\n  }\n);\n\nfunction getToolDefinitions(): ToolDefinition[] {\n  return [...tools.values()];\n}\n\nasync function executeToolCall(toolCall: ToolCall): Promise<ToolResult> {\n  const handler = toolHandlers.get(toolCall.function.name);\n  if (!handler) {\n    return {\n      tool_call_id: toolCall.id,\n      content: `Unknown tool: ${toolCall.function.name}`,\n      isError: true\n    };\n  }\n  try {\n    const args = JSON.parse(toolCall.function.arguments);\n    const result = await handler(args);\n    return { tool_call_id: toolCall.id, content: result };\n  } catch (error) {\n    return {\n      tool_call_id: toolCall.id,\n      content: `Tool execution error: ${error instanceof Error ? error.message : \"Unknown error\"}`,\n      isError: true\n    };\n  }\n}\n\n// ─── In-Memory Store ─────────────────────────────────────────────────────────\n\nconst projects = new Map<string, Project>();\nconst conversations = new Map<string, Conversation>();\nconst skills = new Map<string, Skill>();\nconst automations = new Map<string, Automation>();\n\nawait initializeStore();\n\n// ─── Express Setup ───────────────────────────────────────────────────────────\n\napp.use(cors());\napp.use(express.json({ limit: \"4mb\" }));\n\napp.get(\"/api/health\", (_req, res) => {\n  res.json({\n    ok: true,\n    configured: Boolean(settings.baseUrl && settings.apiKey),\n    model: settings.model,\n    baseUrl: settings.baseUrl,\n    tools: [...tools.keys()]\n  });\n});\n\napp.get(\"/api/app\", (_req, res) => {\n  res.json(getAppState());\n});\n\napp.get(\"/api/settings\", (_req, res) => {\n  res.json(maskSettings(settings));\n});\n\napp.put(\"/api/settings\", (req, res) => {\n  const body = req.body as ApiConfig;\n  if (typeof body.baseUrl === \"string\") settings.baseUrl = body.baseUrl.trim();\n  if (typeof body.apiKey === \"string\") settings.apiKey = body.apiKey.trim();\n  if (typeof body.model === \"string\") settings.model = body.model.trim();\n  res.json(maskSettings(settings));\n});\n\napp.post(\"/api/projects\", async (req, res) => {\n  const { name } = req.body as { name?: string };\n  const project = createProject(name?.trim() || \"新项目\");\n  await persistStore();\n  res.status(201).json(project);\n});\n\napp.post(\"/api/conversations\", async (req, res) => {\n  const body = req.body as { projectId?: string; title?: string };\n  const project = body.projectId ? projects.get(body.projectId) : [...projects.values()][0];\n  if (!project) {\n    res.status(400).json({ error: \"project not found\" });\n    return;\n  }\n\n  const conversation = createConversation(\n    project.id,\n    body.title?.trim() || \"新任务\",\n    `⌘${Math.min(conversations.size + 1, 9)}`\n  );\n  await persistStore();\n  res.status(201).json(conversation);\n});\n\napp.get(\"/api/conversations/:id/messages\", (req, res) => {\n  const conversation = conversations.get(req.params.id);\n  if (!conversation) {\n    res.status(404).json({ error: \"conversation not found\" });\n    return;\n  }\n  res.json({ messages: conversation.messages });\n});\n\n// ─── Agent Loop Endpoint ─────────────────────────────────────────────────────\n\napp.post(\"/api/conversations/:id/messages\", async (req, res) => {\n  const conversation = conversations.get(req.params.id);\n  const { content, config } = req.body as { content?: string; config?: ApiConfig };\n  const prompt = content?.trim();\n\n  if (!conversation) {\n    res.status(404).json({ error: \"conversation not found\" });\n    return;\n  }\n\n  if (!prompt) {\n    res.status(400).json({ error: \"content is required\" });\n    return;\n  }\n\n  const userMessage: Message = {\n    id: id(\"message\"),\n    role: \"user\",\n    content: prompt,\n    createdAt: now()\n  };\n  conversation.messages.push(userMessage);\n  conversation.title = titleFromPrompt(prompt);\n  conversation.updatedAt = now();\n  await persistStore();\n\n  try {\n    const agentResult = await runAgentLoop(conversation, config);\n    res.status(201).json({\n      conversation,\n      userMessage,\n      assistantMessage: agentResult.finalMessage,\n      toolCalls: agentResult.toolCalls,\n      turns: agentResult.turns\n    });\n  } catch (error) {\n    res.status(500).json({\n      error: error instanceof Error ? error.message : \"Unknown server error\"\n    });\n  }\n});\n\napp.post(\"/api/chat\", async (req, res) => {\n  const body = req.body as {\n    messages?: ChatMessage[];\n    config?: ApiConfig;\n  };\n\n  if (!body.messages?.length) {\n    res.status(400).json({ error: \"messages is required\" });\n    return;\n  }\n\n  try {\n    const content = await completeChat(body.messages, body.config);\n    res.json({\n      id: id(\"chat\"),\n      model: body.config?.model ?? settings.model,\n      content,\n      usage: null\n    });\n  } catch (error) {\n    res.status(500).json({\n      error: error instanceof Error ? error.message : \"Unknown server error\"\n    });\n  }\n});\n\napp.get(\"/api/skills\", (_req, res) => {\n  res.json({ skills: [...skills.values()] });\n});\n\napp.post(\"/api/skills/:id/connect\", async (req, res) => {\n  const skill = skills.get(req.params.id);\n  if (!skill) {\n    res.status(404).json({ error: \"skill not found\" });\n    return;\n  }\n\n  skill.connected = true;\n  await persistStore();\n  res.json({ skill });\n});\n\napp.post(\"/api/automations\", async (req, res) => {\n  const { title, schedule } = req.body as { title?: string; schedule?: string };\n  const automation: Automation = {\n    id: id(\"auto\"),\n    title: title?.trim() || \"新自动化\",\n    schedule: schedule?.trim() || \"手动触发\",\n    enabled: true,\n    createdAt: now()\n  };\n  automations.set(automation.id, automation);\n  await persistStore();\n  res.status(201).json({ automation });\n});\n\napp.get(\"/api/search\", (req, res) => {\n  const query = String(req.query.q ?? \"\").trim().toLowerCase();\n  const results = [...conversations.values()]\n    .filter((conversation) => !query || conversation.title.toLowerCase().includes(query))\n    .map((conversation) => ({\n      id: conversation.id,\n      title: conversation.title,\n      projectId: conversation.projectId,\n      type: \"conversation\"\n    }));\n\n  res.json({ results });\n});\n\napp.post(\"/api/tools/run-command\", async (req, res) => {\n  const { command, cwd } = req.body as { command?: string; cwd?: string };\n\n  if (!command) {\n    res.status(400).json({ error: \"command is required\" });\n    return;\n  }\n\n  const denied = DENIED_COMMAND_PATTERNS.find((pattern) => pattern.test(command));\n  if (denied) {\n    res.status(403).json({\n      ok: false,\n      code: 403,\n      stdout: \"\",\n      stderr: `Command blocked by SuperCodex safety policy: ${command}`\n    });\n    return;\n  }\n\n  try {\n    const result = await execAsync(command, {\n      cwd: safeResolvePath(cwd || WORKSPACE_ROOT),\n      timeout: 20_000,\n      maxBuffer: 1024 * 1024\n    });\n\n    res.json({\n      ok: true,\n      stdout: result.stdout,\n      stderr: result.stderr\n    });\n  } catch (error) {\n    const err = error as Error & { stdout?: string; stderr?: string; code?: number };\n    res.status(200).json({\n      ok: false,\n      code: err.code ?? 1,\n      stdout: err.stdout ?? \"\",\n      stderr: err.stderr ?? err.message\n    });\n  }\n});\n\napp.listen(port, () => {\n  console.log(`SuperCodex API listening on http://localhost:${port}`);\n  console.log(`Available tools: ${[...tools.keys()].join(\", \")}`);\n});\n\n// ─── Agent Loop (ReAct) ──────────────────────────────────────────────────────\n\ntype AgentResult = {\n  finalMessage: Message;\n  toolCalls: Array<{ id: string; name: string; args: string; result: string }>;\n  turns: number;\n};\n\nasync function runAgentLoop(\n  conversation: Conversation,\n  config?: ApiConfig\n): Promise<AgentResult> {\n  const chatMessages: ChatMessage[] = [\n    { role: \"system\", content: systemPrompt },\n    ...conversation.messages.map(toChatMessage)\n  ];\n\n  const toolCallLog: Array<{ id: string; name: string; args: string; result: string }> = [];\n  let turns = 0;\n  const allowTools = shouldEnableTools(conversation);\n\n  while (turns < MAX_AGENT_TURNS) {\n    turns++;\n\n    const response = await callLLM(chatMessages, config, allowTools);\n\n    const choice = response.choices?.[0];\n    const message = choice?.message;\n\n    if (!message) {\n      throw new Error(\"LLM returned no choices\");\n    }\n\n    // If LLM wants to call tools\n    if (message.tool_calls && message.tool_calls.length > 0) {\n      const assistantToolMessage: Message = {\n        id: id(\"message\"),\n        role: \"assistant\",\n        content: message.content?.trim() || \"\",\n        tool_calls: message.tool_calls,\n        createdAt: now()\n      };\n      conversation.messages.push(assistantToolMessage);\n      conversation.updatedAt = assistantToolMessage.createdAt;\n\n      // Add assistant message with tool_calls\n      chatMessages.push({\n        role: \"assistant\",\n        content: message.content || null,\n        tool_calls: message.tool_calls\n      });\n\n      // Execute each tool and add results\n      for (const toolCall of message.tool_calls) {\n        const result = await executeToolCall(toolCall);\n        toolCallLog.push({\n          id: toolCall.id,\n          name: toolCall.function.name,\n          args: toolCall.function.arguments,\n          result: result.content\n        });\n\n        conversation.messages.push({\n          id: id(\"message\"),\n          role: \"tool\",\n          content: result.content,\n          tool_call_id: toolCall.id,\n          toolName: toolCall.function.name,\n          createdAt: now()\n        });\n        conversation.updatedAt = now();\n\n        chatMessages.push({\n          role: \"tool\",\n          content: result.content,\n          tool_call_id: toolCall.id,\n          name: toolCall.function.name\n        });\n\n        console.log(`[Tool] ${toolCall.function.name}(${toolCall.function.arguments}) => ${result.content.slice(0, 100)}...`);\n      }\n\n      // Continue loop - LLM will get tool results and decide next step\n      await persistStore();\n      continue;\n    }\n\n    // LLM returned final text response\n    const finalContent = message.content?.trim() || \"模型没有返回内容。\";\n\n    const assistantMessage: Message = {\n      id: id(\"message\"),\n      role: \"assistant\",\n      content: finalContent,\n      createdAt: now()\n    };\n    conversation.messages.push(assistantMessage);\n    conversation.updatedAt = now();\n    await persistStore();\n\n    return {\n      finalMessage: assistantMessage,\n      toolCalls: toolCallLog,\n      turns\n    };\n  }\n\n  // Max turns reached - force a final response\n  chatMessages.push({\n    role: \"system\",\n    content: \"You have reached the maximum number of tool calls. Please provide your final answer based on what you have gathered.\"\n  });\n\n  const response = await callLLM(chatMessages, config, false);\n  const finalContent = response.choices?.[0]?.message?.content?.trim() || \"已达到最大工具调用次数限制。\";\n\n  const assistantMessage: Message = {\n    id: id(\"message\"),\n    role: \"assistant\",\n    content: finalContent,\n    createdAt: now()\n  };\n  conversation.messages.push(assistantMessage);\n  conversation.updatedAt = now();\n  await persistStore();\n\n  return {\n    finalMessage: assistantMessage,\n    toolCalls: toolCallLog,\n    turns\n  };\n}\n\nasync function callLLM(messages: ChatMessage[], config?: ApiConfig, enableTools = false) {\n  const effective = {\n    baseUrl: normalizeBaseUrl(config?.baseUrl || settings.baseUrl),\n    apiKey: config?.apiKey || settings.apiKey,\n    model: config?.model || settings.model\n  };\n\n  if (!effective.baseUrl || !effective.apiKey) {\n    return {\n      choices: [{\n        message: {\n          content: fallbackOfficeReply(messages),\n          tool_calls: undefined\n        }\n      }]\n    } as ChatCompletionResponse;\n  }\n\n  const toolsArray = enableTools ? getToolDefinitions() : [];\n\n  const upstream = await fetch(`${effective.baseUrl}/chat/completions`, {\n    method: \"POST\",\n    headers: {\n      Authorization: `Bearer ${effective.apiKey}`,\n      \"Content-Type\": \"application/json\"\n    },\n    body: JSON.stringify({\n      model: effective.model,\n      messages,\n      ...(toolsArray.length > 0 ? { tools: toolsArray, tool_choice: \"auto\" } : {}),\n 