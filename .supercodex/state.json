          "content": "import cors from \"cors\";\nimport \"dotenv/config\";\nimport express from \"express\";\nimport { exec } from \"node:child_process\";\nimport { promises as fs } from \"node:fs\";\nimport path from \"node:path\";\nimport { promisify } from \"node:util\";\n\nconst execAsync = promisify(exec);\nconst app = express();\nconst port = Number(process.env.PORT ?? 8787);\n\n// ─── Types ───────────────────────────────────────────────────────────────────\n\ntype Role = \"system\" | \"user\" | \"assistant\" | \"tool\";\n\ntype ToolCall = {\n  id: string;\n  type: \"function\";\n  function: { name: string; arguments: string };\n};\n\ntype ChatMessage = {\n  role: Role;\n  content: string | null;\n  tool_calls?: ToolCall[];\n  tool_call_id?: string;\n  name?: string;\n};\n\ntype ToolDefinition = {\n  type: \"function\";\n  function: {\n    name: string;\n    description: string;\n    parameters: Record<string, unknown>;\n  };\n};\n\ntype ToolResult = {\n  tool_call_id: string;\n  content: string;\n  isError?: boolean;\n};\n\ntype ApiConfig = {\n  baseUrl?: string;\n  apiKey?: string;\n  model?: string;\n};\n\ntype Message = {\n  id: string;\n  role: Exclude<Role, \"system\" | \"tool\">;\n  content: string;\n  tool_calls?: ToolCall[];\n  createdAt: string;\n};\n\ntype ToolMessage = {\n  id: string;\n  role: \"tool\";\n  content: string;\n  tool_call_id: string;\n  toolName: string;\n  createdAt: string;\n};\n\ntype StoredMessage = Message | ToolMessage;\n\ntype Conversation = {\n  id: string;\n  projectId: string;\n  title: string;\n  shortcut?: string;\n  updatedAt: string;\n  messages: StoredMessage[];\n};\n\ntype Project = {\n  id: string;\n  name: string;\n  conversations: string[];\n};\n\ntype Skill = {\n  id: string;\n  title: string;\n  description: string;\n  accent: string;\n  connected: boolean;\n  installed: boolean;\n  npmPackage?: string;\n};\n\ntype Automation = {\n  id: string;\n  title: string;\n  schedule: string;\n  enabled: boolean;\n  createdAt: string;\n};\n\ntype ChatCompletionResponse = {\n  id?: string;\n  model?: string;\n  choices?: Array<{\n    message?: {\n      content?: string;\n      tool_calls?: ToolCall[];\n    };\n  }>;\n  usage?: unknown;\n  error?: { message?: string };\n};\n\ntype PersistedStore = {\n  projects: Project[];\n  conversations: Conversation[];\n  skills: Skill[];\n  automations: Automation[];\n};\n\n// ─── Constants ───────────────────────────────────────────────────────────────\n\nconst MAX_AGENT_TURNS = 10;\nconst WORKSPACE_ROOT = process.cwd();\nconst DATA_DIR = path.join(WORKSPACE_ROOT, \".supercodex\");\nconst DATA_FILE = path.join(DATA_DIR, \"state.json\");\nconst DENIED_COMMAND_PATTERNS = [\n  /\\brm\\s+-rf\\b/,\n  /\\bgit\\s+reset\\s+--hard\\b/,\n  /\\bgit\\s+clean\\s+-fd\\b/,\n  /\\bsudo\\b/,\n  />\\s*\\/dev\\/(disk|rdisk)/,\n  /\\bmkfs\\b/,\n  /\\bdd\\s+if=/\n];\n\nconst systemPrompt =\n  \"You are SuperCodex, a general office agent. Help with workplace tasks such as email, documents, research, planning, automation, meetings, operations, and cross-app workflows. \" +\n  \"Be practical, concise, and action-oriented. \" +\n  \"You have access to tools. Use them when they can help complete the task. \" +\n  \"When a tool call is needed, respond with tool_calls. When you have the final answer, respond with plain text content.\";\n\n// ─── Settings ────────────────────────────────────────────────────────────────\n\nconst settings: Required<ApiConfig> = {\n  baseUrl: process.env.API_BASE_URL ?? \"https://api.openai.com/v1\",\n  apiKey: process.env.API_KEY ?? \"\",\n  model: process.env.API_MODEL ?? \"gpt-4.1\"\n};\n\n// ─── Tool Registry ───────────────────────────────────────────────────────────\n\nconst tools = new Map<string, ToolDefinition>();\nconst toolHandlers = new Map<string, (args: Record<string, unknown>) => Promise<string>>();\n\nfunction registerTool(definition: ToolDefinition, handler: (args: Record<string, unknown>) => Promise<string>) {\n  tools.set(definition.function.name, definition);\n  toolHandlers.set(definition.function.name, handler);\n}\n\nregisterTool(\n  {\n    type: \"function\",\n    function: {\n      name: \"search_web\",\n      description: \"Search the web for information. Returns top results.\",\n      parameters: {\n        type: \"object\",\n        properties: {\n          query: { type: \"string\", description: \"Search query\" },\n          num: { type: \"number\", description: \"Number of results (default 5)\" }\n        },\n        required: [\"query\"]\n      }\n    }\n  },\n  async (args) => {\n    const query = String(args.query || \"\");\n    const num = Number(args.num) || 5;\n    try {\n      const url = `https://html.duckduckgo.com/html/?q=${encodeURIComponent(query)}`;\n      const response = await fetch(url, {\n        headers: { \"User-Agent\": \"Mozilla/5.0\" }\n      });\n      const html = await response.text();\n      const results: string[] = [];\n      const regex = /class=\"result__a\"[^>]*href=\"([^\"]*)\"[^>]*>(.*?)<\\/a>/g;\n      let match;\n      while ((match = regex.exec(html)) !== null && results.length < num) {\n        results.push(`[${match[2]}](${match[1]})`);\n      }\n      return results.length > 0\n        ? results.map((r, i) => `${i + 1}. ${r}`).join(\"\\n\")\n        : \"No results found.\";\n    } catch (error) {\n      return `Search failed: ${error instanceof Error ? error.message : \"Unknown error\"}`;\n    }\n\n... (truncated, 861 more lines)",
