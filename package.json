{
  "name": "super-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node dist-server/index.js",
    "reminder": "node scripts/reminder.mjs",
    "reminder:stop": "launchctl unload ~/Library/LaunchAgents/com.supercodex.reminder.plist",
    "reminder:start": "launchctl load ~/Library/LaunchAgents/com.supercodex.reminder.plist",
    "reminder:status": "launchctl list | grep supercodex"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "lucide-react": "^0.552.0",
    "multer": "^2.1.1",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.10",
    "open-websearch": "^2.1.11",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.11"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9"
  }
}
